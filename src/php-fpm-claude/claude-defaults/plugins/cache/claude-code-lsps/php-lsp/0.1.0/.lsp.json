{
    "php": {
        "command": "php-lsp",
        "args": [],
        "transport": "stdio",
        "extensionToLanguage": {
            ".php": "php",
            ".php3": "php",
            ".php4": "php",
            ".php5": "php",
            ".phps": "php",
            ".phtml": "php"
        },
        "initializationOptions": {
            "phpVersion": "8.5",
            "excludePaths": [
                "node_modules/*",
                "storage/*",
                "bootstrap/cache/*",
                "public/build/*"
            ],
            "diagnostics": {
                "enabled": true,
                "undefinedVariables": true,
                "undefinedFunctions": false,
                "undefinedClasses": true,
                "arityErrors": true,
                "typeErrors": true,
                "deprecatedCalls": true,
                "duplicateDeclarations": true
            }
        },
        "settings": {},
        "maxRestarts": 3
    }
}
